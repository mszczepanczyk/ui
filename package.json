{
  "name": "@mariusz.sh/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript UI component library built on Park UI, Ark UI, and Panda CSS",
  "license": "MIT",
  "author": "mariusz.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/mariusz.sh/ui"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": {
      "types": "./dist/styled-system/css/index.d.ts",
      "import": "./dist/styled-system/css/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:docs",
    "build:lib": "panda codegen && vite build",
    "build:docs": "echo 'TODO: docs build'",
    "cosmos": "cosmos",
    "cosmos:export": "cosmos-export",
    "dev": "vite",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "panda codegen",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@ark-ui/react": "^4.5.0",
    "@park-ui/panda-preset": "^0.42.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@pandacss/dev": "^0.47.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-cosmos": "^6.2.0",
    "react-cosmos-plugin-vite": "^6.2.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0"
  }
}
