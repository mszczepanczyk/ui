{
	"name": "@mariusz.sh/ui",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"build": "npm run build:lib",
		"build:lib": "panda codegen && tsc -b && vite build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"dev": "vite",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"prepare": "panda codegen",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@ark-ui/react": "^5.36.2",
		"lucide-react": "^1.16.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@pandacss/dev": "^1.11.1",
		"@types/node": "^24.12.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "~6.0.2",
		"vite": "^8.0.12"
	}
}
