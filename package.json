{
	"name": "@mariusz.sh/ui",
	"version": "0.1.0",
	"description": "A TypeScript UI component library built on Park UI, Ark UI, and Panda CSS",
	"type": "module",
	"license": "MIT",
	"author": "mariusz.sh",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/index.js"
		},
		"./panda-preset": {
			"types": "./dist/src/panda-preset.d.ts",
			"import": "./dist/panda-preset.js"
		},
		"./styles.css": "./dist/styles.css",
		"./styled-system/*": {
			"types": "./styled-system/*.d.ts",
			"import": "./styled-system/*.mjs",
			"default": "./styled-system/*"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/src/index.d.ts",
	"files": [
		"dist",
		"styled-system"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=20",
		"npm": ">=10"
	},
	"scripts": {
		"build": "npm run build:lib && npm run build:css",
		"build:css": "panda cssgen './src/**/*.{ts,tsx}' --cwd . -o dist/styles.css",
		"build:lib": "panda codegen && tsc -b && vite build",
		"cosmos": "cosmos",
		"cosmos:export": "cosmos-export",
		"dev": "cosmos",
		"format": "biome check --write .",
		"lint": "biome check .",
		"prepare": "panda codegen",
		"preview": "vite preview",
		"test:visual": "playwright test",
		"test:visual:report": "playwright show-report",
		"test:visual:update": "playwright test --update-snapshots",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"dependencies": {
		"@ark-ui/react": "^5.36.2",
		"lucide-react": "^1.16.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@pandacss/dev": "^1.11.1",
		"@playwright/test": "^1.60.0",
		"@types/node": "^24.12.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"react": "^19.2.6",
		"react-cosmos": "^7.3.0",
		"react-cosmos-plugin-vite": "^7.3.0",
		"react-dom": "^19.2.6",
		"typescript": "~6.0.2",
		"vite": "^8.0.12",
		"vite-plugin-dts": "^5.0.1"
	}
}
